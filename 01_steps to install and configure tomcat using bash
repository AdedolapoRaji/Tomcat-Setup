#!/bin/bash
# ------------------------------------------------------------------
# Automated Tomcat 9 Installation & Security Fix Script
# Target: Amazon Linux 2 / RHEL / CentOS
# ------------------------------------------------------------------

# 1. Install Java 11 (Required for your Maven project)
echo "Installing Java 11..."
sudo yum install java-11-amazon-corretto -y

# 2. Download and Extract Tomcat 9
echo "Downloading Tomcat 9.0.75..."
cd /opt
sudo wget https://archive.apache.org/dist/tomcat/tomcat-9/v9.0.75/bin/apache-tomcat-9.0.75.tar.gz
sudo tar -xvzf apache-tomcat-9.0.75.tar.gz
sudo mv apache-tomcat-9.0.75 tomcat
sudo chmod -R 755 /opt/tomcat

# 3. FIX: Disable the Remote Address Valve
# This removes the block that causes the 'Connection Timed Out' or '403 Forbidden' 
# when Jenkins tries to deploy to the Manager App.
echo "Applying Remote Address Valve Fix..."
sudo cat <<'EOF' > /opt/tomcat/webapps/manager/META-INF/context.xml
<?xml version="1.0" encoding="UTF-8"?>
<Context antiResourceLocking="false" privileged="true" >
  <CookieProcessor className="org.apache.tomcat.util.http.Rfc6265CookieProcessor"
                   sameSiteCookies="strict" />
  <Manager sessionAttributeValueClassNameFilter="java\.lang\.(?:Boolean|Integer|Long|Number|String)|org\.apache\.catalina\.filters\.CsrfPreventionFilter$Lru" />
</Context>
EOF

# 4. FIX: Configure Users & Roles
# Setting up your specific credentials: tomcat / Tobyte#$63
echo "Configuring Tomcat Users and Roles..."
sudo cat <<EOF > /opt/tomcat/conf/tomcat-users.xml
<?xml version="1.0" encoding="UTF-8"?>
<tomcat-users xmlns="http://tomcat.apache.org/xml" version="1.0">
  <role rolename="manager-gui"/>
  <role rolename="manager-script"/>
  <role rolename="admin-gui"/>
  <user username="tomcat" password="Tobyte#$6" roles="manager-gui,manager-script,admin-gui"/>
</tomcat-users>
EOF

# 5. Start Tomcat Service
echo "Starting Tomcat..."
/opt/tomcat/bin/startup.sh

echo "--------------------------------------------------------"
echo "INSTALLATION COMPLETE"
echo "Tomcat is running on port 8080"
echo "Credentials: tomcat / Tobyte#$6"
echo "--------------------------------------------------------"



