#!/bin/bash
# 1. Clean up any existing Tomcat installation
sudo systemctl stop tomcat 2>/dev/null
sudo rm -rf /opt/tomcat
# 2. Update System and Install Java 11 (Required for Tomcat 9)
sudo dnf update -y
sudo dnf install java-11-amazon-corretto-devel -y
# 3. Create Tomcat Directory and Download Tomcat 9.0.87
sudo mkdir -p /opt/tomcat
cd /tmp
wget https://archive.apache.org/dist/tomcat/tomcat-9/v9.0.87/bin/apache-tomcat-9.0.87.tar.gz
sudo tar -xf apache-tomcat-9.0.87.tar.gz -C /opt/tomcat --strip-components=1
# 4. Set Permissions for ec2-user
cd /opt/tomcat
sudo chown -R ec2-user:ec2-user /opt/tomcat
sudo chmod -R 755 /opt/tomcat/bin
sudo chmod -R 755 /opt/tomcat/conf
# 5. CONFIGURATION: Update tomcat-users.xml
# This injects the required roles and your specific password
sudo sed -i '/<\/tomcat-users>/i \
  <role rolename="manager-gui"/> \
  <role rolename="manager-script"/> \
  <role rolename="admin-gui"/> \
  <role rolename="admin-script"/> \
  <user username="tomcat" password="Tobyte#$6" roles="manager-gui,manager-script,admin-gui,admin-script"/>' /opt/tomcat/conf/tomcat-users.xml
# 6. CONFIGURATION: Disable Remote Access Restrictions
# This comments out the IP Valve that was causing your 403 error
sudo sed -i 's/<Valve //g' /opt/tomcat/webapps/manager/META-INF/context.xml
sudo sed -i 's/<Valve //g' /opt/tomcat/webapps/host-manager/META-INF/context.xml
# 7. Start Tomcat
sudo /opt/tomcat/bin/startup.sh
echo "------------------------------------------------------------"
echo "✅ Tomcat 9 Clean Installation & Configuration Complete!"
echo "URL: http://$(curl -s http://checkip.amazonaws.com):8080"
echo "Username: tomcat"
