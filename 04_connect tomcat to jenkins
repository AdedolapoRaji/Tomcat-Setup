        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/your-repo/netflix-clone.git'
            }
        }
stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
stage('deploy') {
            steps {
                deploy adapters: [
                    tomcat9(
